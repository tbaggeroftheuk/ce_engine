{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Project",
      "type": "shell",
      "command": "make",
      "options": {
        "cwd": "/mnt/projects/Coding/C/game"
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Move Executable",
      "type": "shell",
      "command": "mv",
      "args": [
        "hello",                  // <-- your actual compiled executable
        "build/Debug/outDebug"
      ],
      "options": {
        "cwd": "/mnt/projects/Coding/C/game"
      }
    },
    {
      "label": "Copy data.tcf",
      "type": "shell",
      "command": "cp",
      "args": [
        "data.tcf",
        "build/Debug/"
      ],
      "options": {
        "cwd": "/mnt/projects/Coding/C/game"
      }
    },
    {
      "label": "Build & Prepare Debug",
      "dependsOn": ["Build Project", "Move Executable", "Copy data.tcf"]
    }
  ]
}
